# Picket configuration.
# Copy this to ~/.config/picket/.env and fill it in:
#   mkdir -p ~/.config/picket && cp config.example.env ~/.config/picket/.env
# Then load it before running Picket:  set -a; . ~/.config/picket/.env; set +a

# Your GitHub username or org — the account whose repos Picket watches.
PICKET_OWNER=your-github-username

# The GitHub App Picket acts as. See SETUP.md to create it, then put its
# numeric App ID here and the path to its private key below.
PICKET_APP_ID=000000
PICKET_APP_KEY=~/.config/picket/app.pem

# Optional: a free push topic (https://ntfy.sh) to get pinged on tier-3
# (secret / auth) findings. Leave unset to skip push notifications.
# PICKET_NTFY_TOPIC=https://ntfy.sh/your-private-topic

# Optional: a Telegram heads-up whenever something needs your review (a tier-2
# PR Picket opened, or a tier-3 escalation). Create a bot with @BotFather for
# the token; message your bot once, then read your numeric chat id from
# https://api.telegram.org/bot<TOKEN>/getUpdates (the .message.chat.id field).
# PICKET_TELEGRAM_BOT_TOKEN=123456789:ABCdef...
# PICKET_TELEGRAM_CHAT_ID=000000000

# Optional: auto-merge trusted-author PRs that are safe (python -m picket.automerge).
# Comma-separated GitHub logins you trust. dependabot[bot] is trusted by default;
# add your own username to auto-merge your own green, non-sensitive PRs. A PR only
# merges when CI is green, it touches no secret/auth/payment path, and it is not a
# fork or draft -- and never until you add its repo to config/live_allowlist.txt.
# PICKET_TRUSTED_PR_AUTHORS=your-github-username,dependabot[bot]
